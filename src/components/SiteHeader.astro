---
import ThemeSwitcher from './ThemeSwitcher.astro';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about-us/', label: 'About' },
  { href: '/privacy-policy/', label: 'Privacy' },
  { href: '/terms-and-conditions/', label: 'Terms' },
  { href: '/contact-us/', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-50 w-full bg-canvas/85 backdrop-blur-md border-b border-hairline shadow-sm">
  <div class="w-full max-w-7xl mx-auto px-4 md:px-6 py-3 flex flex-wrap items-center justify-between gap-3">
    <a href="/" class="flex min-w-0 items-center gap-2 group">
      <img src="/icon.png" alt="Universal QR Code Tools" width="32" height="32" class="h-8 w-8 rounded-sm shadow-level-1 transition-transform group-hover:scale-105" />
      <span class="font-sans font-semibold tracking-tight text-ink text-sm whitespace-nowrap">Universal.</span>
    </a>

    <nav class="order-3 flex w-full items-center gap-1 overflow-x-auto border-t border-hairline pt-3 text-xs md:order-none md:w-auto md:border-t-0 md:pt-0" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'whitespace-nowrap rounded-sm px-3 py-2 font-medium transition-colors hover:bg-canvas-soft-2 hover:text-ink focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary',
            isActive(item.href) ? 'bg-primary text-on-primary hover:bg-primary hover:text-on-primary' : 'text-body',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <ThemeSwitcher />
  </div>
</header>
