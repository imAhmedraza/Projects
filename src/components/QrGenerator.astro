                p { font-size: 14px; color: #4d4d4d; word-break: break-all; max-width: 80%; margin: 0 auto 30px; }
                .footer { font-size: 11px; color: #888888; margin-top: 40px; font-family: monospace; }
                @media print {
                  body { padding: 0; }
