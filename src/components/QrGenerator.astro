---
// src/components/QrGenerator.astro
---

<div class="w-full max-w-6xl mx-auto px-4 md:px-6 py-12 relative z-10">
  <!-- Hero / Header Section -->
  <div class="text-center mb-16 relative">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-canvas-soft border border-hairline text-xs font-mono text-body mb-4 shadow-sm">
      <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
      Version 2.0 Released
    </div>
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-ink mb-4 leading-none font-sans">
      Universal QR Generator.
    </h1>
    <p class="text-lg text-body max-w-2xl mx-auto font-sans">
      Generate customized, print-ready, high-fidelity QR codes with custom styling, dot shape adjustments, and logo overlays.
    </p>
  </div>

  <!-- Main Generator Workspace -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start mb-16">
    <!-- Left Column: Inputs and Options (8 cols on desktop) -->
    <div class="lg:col-span-7 space-y-6">
      
      <!-- Content Type Tabs -->
      <div class="bg-canvas border border-hairline rounded-md p-1 shadow-level-2">
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-1" role="tablist" id="content-tabs">
          <button type="button" class="tab-btn active px-3 py-2 text-xs font-medium rounded-sm transition-colors duration-200 cursor-pointer flex flex-col items-center gap-1 bg-primary text-on-primary" data-tab="url" role="tab" aria-selected="true">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            URL
          </button>
          <button type="button" class="tab-btn px-3 py-2 text-xs font-medium rounded-sm transition-colors duration-200 cursor-pointer flex flex-col items-center gap-1 text-body hover:text-ink hover:bg-canvas-soft-2" data-tab="wifi" role="tab" aria-selected="false">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20" stroke-width="3"/></svg>
            WiFi
          </button>
          <button type="button" class="tab-btn px-3 py-2 text-xs font-medium rounded-sm transition-colors duration-200 cursor-pointer flex flex-col items-center gap-1 text-body hover:text-ink hover:bg-canvas-soft-2" data-tab="contact" role="tab" aria-selected="false">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Contact
          </button>
          <button type="button" class="tab-btn px-3 py-2 text-xs font-medium rounded-sm transition-colors duration-200 cursor-pointer flex flex-col items-center gap-1 text-body hover:text-ink hover:bg-canvas-soft-2" data-tab="email" role="tab" aria-selected="false">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email
          </button>
          <button type="button" class="tab-btn px-3 py-2 text-xs font-medium rounded-sm transition-colors duration-200 cursor-pointer flex flex-col items-center gap-1 text-body hover:text-ink hover:bg-canvas-soft-2" data-tab="sms" role="tab" aria-selected="false">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            SMS
          </button>
          <button type="button" class="tab-btn px-3 py-2 text-xs font-medium rounded-sm transition-colors duration-200 cursor-pointer flex flex-col items-center gap-1 text-body hover:text-ink hover:bg-canvas-soft-2" data-tab="phone" role="tab" aria-selected="false">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Phone
          </button>
        </div>
      </div>

      <!-- Tab Content Card -->
      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3">
        <!-- URL Input -->
        <div id="tab-content-url" class="tab-pane">
          <label for="input-url" class="block text-xs font-mono uppercase text-body mb-2">Website URL or Text Content</label>
          <input type="url" id="input-url" name="url" autocomplete="off" inputmode="url" spellcheck="false" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="https://example.com…" value="https://example.com" />
        </div>

        <!-- WiFi Input -->
        <div id="tab-content-wifi" class="tab-pane hidden space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="input-wifi-ssid" class="block text-xs font-mono uppercase text-body mb-2">Network Name (SSID)</label>
              <input type="text" id="input-wifi-ssid" name="wifi_ssid" autocomplete="off" spellcheck="false" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="My Home WiFi…" />
            </div>
            <div>
              <label for="input-wifi-encryption" class="block text-xs font-mono uppercase text-body mb-2">Encryption Type</label>
              <select id="input-wifi-encryption" name="wifi_encryption" class="h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none cursor-pointer">
                <option value="WPA">WPA / WPA2</option>
                <option value="WEP">WEP</option>
                <option value="nopass">None (Open)</option>
              </select>
            </div>
          </div>
          <div>
            <label for="input-wifi-password" class="block text-xs font-mono uppercase text-body mb-2">Network Password</label>
            <input type="password" id="input-wifi-password" name="wifi_password" autocomplete="off" spellcheck="false" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="••••••••" />
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="input-wifi-hidden" name="wifi_hidden" class="rounded border-hairline text-primary focus:ring-primary focus-visible:ring-1 focus-visible:ring-primary h-4 w-4 cursor-pointer" />
            <label for="input-wifi-hidden" class="text-xs text-body select-none cursor-pointer">This network is hidden</label>
          </div>
        </div>

        <!-- Contact (vCard) Input -->
        <div id="tab-content-contact" class="tab-pane hidden space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="input-contact-first" class="block text-xs font-mono uppercase text-body mb-2">First Name</label>
              <input type="text" id="input-contact-first" name="first_name" autocomplete="given-name" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="John" />
            </div>
            <div>
              <label for="input-contact-last" class="block text-xs font-mono uppercase text-body mb-2">Last Name</label>
              <input type="text" id="input-contact-last" name="last_name" autocomplete="family-name" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="Doe" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="input-contact-phone" class="block text-xs font-mono uppercase text-body mb-2">Phone Number</label>
              <input type="tel" id="input-contact-phone" name="phone" autocomplete="tel" inputmode="tel" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="+1 (555) 019-2834…" />
            </div>
            <div>
              <label for="input-contact-email" class="block text-xs font-mono uppercase text-body mb-2">Email Address</label>
              <input type="email" id="input-contact-email" name="email" autocomplete="email" spellcheck="false" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="john.doe@gmail.com…" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="input-contact-org" class="block text-xs font-mono uppercase text-body mb-2">Company / Organization</label>
              <input type="text" id="input-contact-org" name="organization" autocomplete="organization" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="Vercel Inc." />
            </div>
            <div>
              <label for="input-contact-title" class="block text-xs font-mono uppercase text-body mb-2">Job Title</label>
              <input type="text" id="input-contact-title" name="job_title" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="Staff Software Engineer" />
            </div>
          </div>
          <div>
            <label for="input-contact-url" class="block text-xs font-mono uppercase text-body mb-2">Website</label>
            <input type="url" id="input-contact-url" name="contact_url" autocomplete="url" inputmode="url" spellcheck="false" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="https://johndoe.dev…" />
          </div>
          <div>
            <label for="input-contact-address" class="block text-xs font-mono uppercase text-body mb-2">Work Address</label>
            <input type="text" id="input-contact-address" name="address" autocomplete="street-address" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="100 California St, San Francisco, CA" />
          </div>
        </div>

        <!-- Email Input -->
        <div id="tab-content-email" class="tab-pane hidden space-y-4">
          <div>
            <label for="input-email-to" class="block text-xs font-mono uppercase text-body mb-2">Recipient Email</label>
            <input type="email" id="input-email-to" name="email_to" autocomplete="email" spellcheck="false" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="hello@company.com…" />
          </div>
          <div>
            <label for="input-email-subject" class="block text-xs font-mono uppercase text-body mb-2">Subject Line</label>
            <input type="text" id="input-email-subject" name="email_subject" autocomplete="off" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="Feedback on presentation…" />
          </div>
          <div>
            <label for="input-email-body" class="block text-xs font-mono uppercase text-body mb-2">Email Body Message</label>
            <textarea id="input-email-body" name="email_body" rows="4" class="form-input-box p-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none resize-none" placeholder="Type your message details here…"></textarea>
          </div>
        </div>

        <!-- SMS Input -->
        <div id="tab-content-sms" class="tab-pane hidden space-y-4">
          <div>
            <label for="input-sms-phone" class="block text-xs font-mono uppercase text-body mb-2">Phone Number</label>
            <input type="tel" id="input-sms-phone" name="sms_phone" autocomplete="tel" inputmode="tel" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="+15551234567…" />
          </div>
          <div>
            <label for="input-sms-body" class="block text-xs font-mono uppercase text-body mb-2">SMS Message</label>
            <textarea id="input-sms-body" name="sms_body" rows="3" class="form-input-box p-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none resize-none" placeholder="Hello! Text me back at this number."></textarea>
          </div>
        </div>

        <!-- Phone Input -->
        <div id="tab-content-phone" class="tab-pane hidden">
          <label for="input-phone-num" class="block text-xs font-mono uppercase text-body mb-2">Phone Number</label>
          <input type="tel" id="input-phone-num" name="phone_num" autocomplete="tel" inputmode="tel" class="form-input-box h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary w-full transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" placeholder="+15551234567…" />
        </div>
      </div>

      <!-- Advanced Customization Accordions -->
      <div class="space-y-4">
        
        <!-- Accordion Item 1: Style Presets -->
        <div class="bg-canvas border border-hairline rounded-md overflow-hidden shadow-level-2 accordion-item">
          <button type="button" aria-expanded="true" class="w-full px-6 py-4 flex items-center justify-between text-sm font-medium text-ink bg-canvas hover:bg-canvas-soft-2 cursor-pointer transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" data-accordion-trigger>
            <span class="flex items-center gap-2">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              Style Presets
            </span>
            <svg class="chevron transition-transform duration-200 transform rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          
          <div class="px-6 py-4 border-t border-hairline bg-canvas-soft space-y-4 accordion-content">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="select-dot-style" class="block text-xs font-mono uppercase text-body mb-2">Dot Pattern</label>
                <select id="select-dot-style" class="opt-control h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none w-full cursor-pointer transition-colors">
                  <option value="square">Standard Square</option>
                  <option value="rounded">Rounded Squares</option>
                  <option value="dots">Classy Dots</option>
                </select>
              </div>
              <div>
                <label for="select-finder-style" class="block text-xs font-mono uppercase text-body mb-2">Corner Eyes</label>
                <select id="select-finder-style" class="opt-control h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none w-full cursor-pointer transition-colors">
                  <option value="square">Sharp Square</option>
                  <option value="rounded">Smooth Rounded</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Accordion Item 2: Custom Brand Colors -->
        <div class="bg-canvas border border-hairline rounded-md overflow-hidden shadow-level-2 accordion-item">
          <button type="button" aria-expanded="false" class="w-full px-6 py-4 flex items-center justify-between text-sm font-medium text-ink bg-canvas hover:bg-canvas-soft-2 cursor-pointer transition-colors focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none" data-accordion-trigger>
            <span class="flex items-center gap-2">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 14.7255 3.09032 17.1962 4.85857 19C5.03345 19.1766 5.09912 19.431 5.029 19.6617L4.6 21.0718C4.51528 21.35 4.75782 21.609 5.0425 21.5378L6.47192 21.1805C6.70275 21.1228 6.94977 21.196 7.12157 21.3678C8.48375 21.7772 9.94318 22 12 22Z"/><circle cx="7.5" cy="10.5" r="1.5"/><circle cx="11.5" cy="7.5" r="1.5"/><circle cx="16.5" cy="9.5" r="1.5"/></svg>
              Brand Colors
            </span>
            <svg class="chevron transition-transform duration-200 transform rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          
          <div class="px-6 py-4 border-t border-hairline bg-canvas-soft space-y-4 accordion-content">
            <!-- Color presets row -->
            <div>
              <span class="block text-xs font-mono uppercase text-body mb-2">Preset Themes</span>
              <div class="flex flex-wrap gap-2">
                <button type="button" class="preset-theme-btn w-6 h-6 rounded-full border border-hairline bg-primary relative cursor-pointer group" data-fg="#171717" data-bg="#ffffff" title="Classic Vercel Ink" aria-label="Set theme to Classic Vercel Ink">
                  <span class="absolute inset-0 rounded-full border-2 border-white scale-0 transition-transform active-check"></span>
                </button>
                <button type="button" class="preset-theme-btn w-6 h-6 rounded-full border border-hairline bg-success relative cursor-pointer group" data-fg="#0070f3" data-bg="#ffffff" title="Hyper Blue" aria-label="Set theme to Hyper Blue">
                  <span class="absolute inset-0 rounded-full border-2 border-white scale-0 transition-transform active-check"></span>
                </button>
                <button type="button" class="preset-theme-btn w-6 h-6 rounded-full border border-hairline bg-violet relative cursor-pointer group" data-fg="#7928ca" data-bg="#ffffff" title="Premium Violet" aria-label="Set theme to Premium Violet">
                  <span class="absolute inset-0 rounded-full border-2 border-white scale-0 transition-transform active-check"></span>
                </button>
                <button type="button" class="preset-theme-btn w-6 h-6 rounded-full border border-hairline bg-warning relative cursor-pointer group" data-fg="#f5a623" data-bg="#ffffff" title="Warm Amber" aria-label="Set theme to Warm Amber">
                  <span class="absolute inset-0 rounded-full border-2 border-white scale-0 transition-transform active-check"></span>
                </button>
                <button type="button" class="preset-theme-btn w-6 h-6 rounded-full border border-hairline bg-gradient-to-r from-pink-500 to-rose-500 relative cursor-pointer group" data-fg="#ff0080" data-bg="#ffffff" title="Bright Pink" aria-label="Set theme to Bright Pink">
                  <span class="absolute inset-0 rounded-full border-2 border-white scale-0 transition-transform active-check"></span>
                </button>
                <button type="button" class="preset-theme-btn w-6 h-6 rounded-full border border-hairline bg-emerald-500 relative cursor-pointer group" data-fg="#10b981" data-bg="#ffffff" title="Forest Emerald" aria-label="Set theme to Forest Emerald">
                  <span class="absolute inset-0 rounded-full border-2 border-white scale-0 transition-transform active-check"></span>
                </button>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Foreground color picker -->
              <div>
                <label for="color-fg" class="block text-xs font-mono uppercase text-body mb-2">Foreground Color</label>
                <div class="flex gap-2">
                  <input type="color" id="color-fg" class="opt-control w-10 h-10 border border-hairline rounded-sm cursor-pointer p-0.5 bg-canvas" value="#171717" aria-label="Foreground color picker" />
                  <input type="text" id="color-fg-text" class="h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary focus-visible:ring-1 focus-visible:ring-primary focus-visible:outline-none w-full text-center font-mono transition-colors" value="#171717" maxlength="7" aria-label="Foreground color hex code" />
                </div>
              </div>

              <!-- Background color picker -->
