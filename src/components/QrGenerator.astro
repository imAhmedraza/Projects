                  cursor: pointer;
                  margin-bottom: 20px;
                }
                button:hover { background: black; }
              </style>
            </head>
            <body>
              <div class="container">
                <button onclick="window.print()">Print QR Poster</button>
                <br />
                <img src="${dataUrl}" alt="QR Code" />
                <h2>Scan QR Code</h2>
                <p>${contentVal}</p>
                <div class="footer">Universal QR Code Generator • ${new Date().toLocaleDateString()}</div>
              </div>
            </body>
          </html>
        `);
        printWindow.document.close();
      });
    }

    // Helper to generate SVG xml content matching the canvas
    function getSvgString(): string {
      const content = generateQrContent();
      const dotStyle = (document.getElementById('select-dot-style') as HTMLSelectElement)?.value || 'square';
      const finderStyle = (document.getElementById('select-finder-style') as HTMLSelectElement)?.value || 'square';
      const errorCorrection = (document.getElementById('select-error-level') as HTMLSelectElement)?.value || 'M';
      const fgColorVal = colorFg.value;
      const bgColorVal = checkTransparent.checked ? 'none' : colorBg.value;
      const logoSize = parseFloat(logoSizeSlider.value) / 100;

      const qr = QRCode.create(content, { errorCorrectionLevel: errorCorrection as QRCode.QRCodeErrorCorrectionLevel });
      const size = qr.modules.size;
      const margin = 4;
      const totalModules = size + margin * 2;
      
      let svgPaths: string[] = [];

      const isFinder = (row: number, col: number) => {
        return (
          (row < 7 && col < 7) ||
          (row < 7 && col >= size - 7) ||
          (row >= size - 7 && col < 7)
        );
      };

      // Traverse modules
      for (let r = 0; r < size; r++) {
        for (let c = 0; c < size; c++) {
          if (isFinder(r, c)) continue;
          
          const isDark = qr.modules.get(r, c);
          if (!isDark) continue;

          const x = margin + c;
          const y = margin + r;

          if (dotStyle === 'dots') {
            svgPaths.push(`<circle cx="${x + 0.5}" cy="${y + 0.5}" r="0.4" fill="${fgColorVal}" />`);
          } else if (dotStyle === 'rounded') {
            svgPaths.push(`<rect x="${x + 0.05}" y="${y + 0.05}" width="0.9" height="0.9" rx="0.25" ry="0.25" fill="${fgColorVal}" />`);
          } else {
            svgPaths.push(`<rect x="${x}" y="${y}" width="1" height="1" fill="${fgColorVal}" />`);
          }
        }
      }

      // Draw SVG Finder patterns
      const drawSvgFinder = (x: number, y: number) => {
        const rOuter = finderStyle === 'rounded' ? 1.5 : 0;
        const rInner = finderStyle === 'rounded' ? 0.5 : 0;

        // Custom path constructs or rect overlays
        // Drawing outer frame as a stroke rect
        const outerRect = `<rect x="${x + 0.5}" y="${y + 0.5}" width="6" height="6" rx="${rOuter}" ry="${rOuter}" fill="none" stroke="${fgColorVal}" stroke-width="1" />`;
        const innerRect = `<rect x="${x + 2}" y="${y + 2}" width="3" height="3" rx="${rInner}" ry="${rInner}" fill="${fgColorVal}" />`;
        
        svgPaths.push(outerRect);
        svgPaths.push(innerRect);
      };

      drawSvgFinder(margin, margin);
      drawSvgFinder(margin + size - 7, margin);
      drawSvgFinder(margin, margin + size - 7);

      // Embedded logo block if exist
      if (uploadedLogoImage && uploadedLogoDataUrl) {
        const maxLogoSize = size * logoSize;
        const logoX = margin + (size - maxLogoSize) / 2;
        const logoY = margin + (size - maxLogoSize) / 2;
        const bgPadding = 0.5;
        
        const cardSize = maxLogoSize + bgPadding * 2;
        const cardX = logoX - bgPadding;
        const cardY = logoY - bgPadding;
        const cardRadius = finderStyle === 'rounded' ? 1 : 0.2;
        
        const logoBgColor = bgColorVal === 'none' ? '#ffffff' : bgColorVal;

        // Draw backdrop logo card path
        svgPaths.push(`<rect x="${cardX}" y="${cardY}" width="${cardSize}" height="${cardSize}" rx="${cardRadius}" fill="${logoBgColor}" stroke="#ebebeb" stroke-width="0.05" />`);
        
        // Base64 Logo image embedded
        svgPaths.push(`<image href="${uploadedLogoDataUrl}" x="${logoX}" y="${logoY}" width="${maxLogoSize}" height="${maxLogoSize}" />`);
      }

      return `<?xml version="1.0" encoding="utf-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${totalModules} ${totalModules}" width="100%" height="100%">
  ${bgColorVal !== 'none' ? `<rect width="${totalModules}" height="${totalModules}" fill="${bgColorVal}" />` : ''}
  <g>
    ${svgPaths.join('\n    ')}
  </g>
</svg>`;
    }

    // --- Success Toast Display ---
    function showToast(msg: string) {
      if (!toast || !toastMsg) return;
      toastMsg.textContent = msg;
      
      toast.classList.remove('translate-y-12', 'opacity-0', 'pointer-events-none');
      toast.classList.add('translate-y-0', 'opacity-100');

      setTimeout(() => {
        toast.classList.add('translate-y-12', 'opacity-0', 'pointer-events-none');
        toast.classList.remove('translate-y-0', 'opacity-100');
      }, 3000);
    }

    // --- Local Storage History Logs ---
    interface HistoryItem {
      id: string;
      tab: string;
      data: string;
      formData: Record<string, string | boolean>;
      thumbnail: string;
      date: string;
    }

    function saveToHistory() {
      const content = generateQrContent();
      const thumbnailData = qrCanvas.toDataURL('image/png');
      
      // Grab all form input values
      const formData: Record<string, string | boolean> = {};
      const inputs = document.querySelectorAll('.form-input-box, .opt-control');
      inputs.forEach(el => {
        const id = el.id;
        if (!id) return;
        if (el instanceof HTMLInputElement) {
          if (el.type === 'checkbox') {
            formData[id] = el.checked;
          } else {
            formData[id] = el.value;
          }
        } else if (el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement) {
          formData[id] = el.value;
        }
      });

      // Also grab logo states
      formData['logo_uploaded'] = !!uploadedLogoImage;
      formData['logo_filename'] = uploadedLogoFilename;
      formData['logo_data_url'] = uploadedLogoDataUrl;
      formData['active_tab'] = activeTab;

      const item: HistoryItem = {
        id: `qr_${Date.now()}`,
        tab: activeTab.toUpperCase(),
        data: content.length > 40 ? content.substring(0, 37) + '...' : content,
        formData,
        thumbnail: thumbnailData,
        date: new Date().toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
      };

      try {
        let history = JSON.parse(localStorage.getItem(historyKey) || '[]') as HistoryItem[];
        
        // Remove duplicates of same content to avoid flooding
        history = history.filter(h => h.data !== item.data || h.tab !== item.tab);
        
        // Limit history to 6 records
        history.unshift(item);
        if (history.length > 6) history.pop();

        localStorage.setItem(historyKey, JSON.stringify(history));
        loadHistoryList();
      } catch (err) {
        console.error('Failed to write history in localStorage:', err);
      }
    }

    function loadHistoryList() {
      try {
        const history = JSON.parse(localStorage.getItem(historyKey) || '[]') as HistoryItem[];
        
        if (!historyGrid || !historyEmpty || !btnClearHistory) return;

        if (history.length === 0) {
          historyEmpty.classList.remove('hidden');
          historyGrid.classList.add('hidden');
          btnClearHistory.classList.add('hidden');
          return;
        }

        historyEmpty.classList.add('hidden');
        historyGrid.classList.remove('hidden');
        btnClearHistory.classList.remove('hidden');

        historyGrid.innerHTML = '';

        history.forEach((item) => {
          const card = document.createElement('div');
          card.className = 'bg-canvas border border-hairline rounded-md p-4 flex gap-4 items-center shadow-level-2 group hover:border-primary transition-colors';
          
          card.innerHTML = `
            <div class="w-16 h-16 bg-white border border-hairline rounded p-1 flex-shrink-0 flex items-center justify-center">
              <img src="${item.thumbnail}" alt="QR Thumbnail" class="w-full h-full object-contain" />
            </div>
            <div class="flex-grow min-w-0">
              <div class="flex items-center gap-1.5 mb-0.5">
                <span class="text-[10px] font-mono font-semibold tracking-wide uppercase px-1.5 py-0.5 rounded bg-canvas-soft border border-hairline text-body">${item.tab}</span>
                <span class="text-[9px] text-mute font-mono">${item.date}</span>
              </div>
              <p class="text-xs text-ink truncate font-mono mb-2" title="${item.data}">${item.data}</p>
              <div class="flex gap-2">
                <button class="btn-load-h text-[11px] font-medium text-primary hover:underline cursor-pointer" data-id="${item.id}">Load Settings</button>
                <button class="btn-delete-h text-[11px] font-medium text-mute hover:text-error cursor-pointer" data-id="${item.id}">Delete</button>
              </div>
            </div>
          `;

          // Attach click handlers
          card.querySelector('.btn-load-h')?.addEventListener('click', () => loadSettingsFromHistory(item.id));
          card.querySelector('.btn-delete-h')?.addEventListener('click', () => deleteFromHistory(item.id));

          historyGrid.appendChild(card);
        });

      } catch (err) {
        console.error('Failed to load history:', err);
      }
    }

    function deleteFromHistory(id: string) {
      try {
        let history = JSON.parse(localStorage.getItem(historyKey) || '[]') as HistoryItem[];
        history = history.filter(h => h.id !== id);
        localStorage.setItem(historyKey, JSON.stringify(history));
        loadHistoryList();
        showToast('History item removed.');
      } catch (err) {
        console.error(err);
      }
    }

    if (btnClearHistory) {
      btnClearHistory.addEventListener('click', () => {
        localStorage.removeItem(historyKey);
        loadHistoryList();
        showToast('Local history cleared.');
      });
    }

    function loadSettingsFromHistory(id: string) {
      try {
        const history = JSON.parse(localStorage.getItem(historyKey) || '[]') as HistoryItem[];
        const item = history.find(h => h.id === id);
        if (!item) return;

        const data = item.formData;
        activeTab = data['active_tab'] as string || 'url';

        // Update Tab active button
        tabBtns.forEach((btn) => {
          btn.classList.remove('active', 'bg-primary', 'text-on-primary');
          btn.classList.add('text-body', 'hover:text-ink', 'hover:bg-canvas-soft-2');
          btn.setAttribute('aria-selected', 'false');
          if (btn.getAttribute('data-tab') === activeTab) {
            btn.classList.add('active', 'bg-primary', 'text-on-primary');
            btn.classList.remove('text-body', 'hover:text-ink', 'hover:bg-canvas-soft-2');
            btn.setAttribute('aria-selected', 'true');
          }
        });

        // Toggle visibility of panels
        tabPanes.forEach((pane) => pane.classList.add('hidden'));
        const targetPanel = document.getElementById(`tab-content-${activeTab}`);
        if (targetPanel) targetPanel.classList.remove('hidden');

        // Restore form control values
        Object.keys(data).forEach((key) => {
          const el = document.getElementById(key);
          if (!el) return;

          const val = data[key];
          if (el instanceof HTMLInputElement) {
            if (el.type === 'checkbox') {
              el.checked = !!val;
            } else {
              el.value = val as string;
            }
          } else if (el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement) {
            el.value = val as string;
          }
        });

        // Handle logo reload
        const hasLogo = !!data['logo_uploaded'];
        if (hasLogo && data['logo_data_url']) {
          uploadedLogoFilename = data['logo_filename'] as string || 'logo.png';
          uploadedLogoDataUrl = data['logo_data_url'] as string;
          
          if (logoFilename) logoFilename.textContent = uploadedLogoFilename;
          btnClearLogo?.classList.remove('hidden');
          logoSettingsPanel?.classList.remove('hidden');

          const img = new Image();
          img.onload = () => {
            uploadedLogoImage = img;
            updateQrCode();
          };
          img.src = uploadedLogoDataUrl;
        } else {
          uploadedLogoImage = null;
          uploadedLogoFilename = '';
          uploadedLogoDataUrl = '';
          if (logoUpload) logoUpload.value = '';
          if (logoFilename) logoFilename.textContent = 'No file uploaded';
          btnClearLogo?.classList.add('hidden');
          logoSettingsPanel?.classList.add('hidden');
        }

        // Color sync
        if (colorFg && colorFgText) colorFgText.value = colorFg.value.toUpperCase();
        if (colorBg && colorBgText) colorBgText.value = colorBg.value.toUpperCase();
        if (checkTransparent && colorBg && colorBgText) {
          const isTrans = checkTransparent.checked;
          colorBg.disabled = isTrans;
          colorBgText.disabled = isTrans;
          if (isTrans) colorBgText.classList.add('opacity-50');
          else colorBgText.classList.remove('opacity-50');
        }

        updateQrCode();
        showToast('Settings loaded from history.');
      } catch (err) {
        console.error('Failed to load settings from history:', err);
      }
    }

    // Initialize QR Code & Load History Grid
    updateQrCode();
    loadHistoryList();
  });
</script>

