    // --- QR Code Content Formulator ---
    function generateQrContent(): string {
      switch (activeTab) {
        case 'url':
          const urlInput = (document.getElementById('input-url') as HTMLInputElement)?.value.trim();
          return urlInput || 'https://example.com';
          
        case 'wifi':
          const ssid = (document.getElementById('input-wifi-ssid') as HTMLInputElement)?.value.trim() || 'SSID';
          const enc = (document.getElementById('input-wifi-encryption') as HTMLInputElement)?.value || 'WPA';
          const pw = (document.getElementById('input-wifi-password') as HTMLInputElement)?.value || '';
          const hidden = (document.getElementById('input-wifi-hidden') as HTMLInputElement)?.checked ? 'true' : 'false';
          // Format: WIFI:S:SSID;T:WPA;P:PASSWORD;H:true;;
          return `WIFI:S:${ssid};T:${enc};P:${pw};H:${hidden};;`;
          
        case 'contact':
          const first = (document.getElementById('input-contact-first') as HTMLInputElement)?.value.trim();
          const last = (document.getElementById('input-contact-last') as HTMLInputElement)?.value.trim();
          const phone = (document.getElementById('input-contact-phone') as HTMLInputElement)?.value.trim();
          const email = (document.getElementById('input-contact-email') as HTMLInputElement)?.value.trim();
          const org = (document.getElementById('input-contact-org') as HTMLInputElement)?.value.trim();
          const job = (document.getElementById('input-contact-title') as HTMLInputElement)?.value.trim();
          const web = (document.getElementById('input-contact-url') as HTMLInputElement)?.value.trim();
          const addr = (document.getElementById('input-contact-address') as HTMLInputElement)?.value.trim();

          // Build vCard string
          let vcard = 'BEGIN:VCARD\nVERSION:3.0\n';
          if (first || last) vcard += `N:${last || ''};${first || ''};;;\nFN:${first || ''} ${last || ''}\n`;
          if (org) vcard += `ORG:${org}\n`;
          if (job) vcard += `TITLE:${job}\n`;
          if (phone) vcard += `TEL;TYPE=CELL:${phone}\n`;
          if (email) vcard += `EMAIL;TYPE=PREF,INTERNET:${email}\n`;
          if (web) vcard += `URL:${web}\n`;
          if (addr) vcard += `ADR;TYPE=WORK:;;${addr};;;;\n`;
          vcard += 'END:VCARD';
          return vcard;

        case 'email':
          const to = (document.getElementById('input-email-to') as HTMLInputElement)?.value.trim();
          const subj = (document.getElementById('input-email-subject') as HTMLInputElement)?.value.trim();
          const body = (document.getElementById('input-email-body') as HTMLTextAreaElement)?.value.trim();
          // Format: MATMSG:TO:email;SUB:subject;BODY:message;;
          return `MATMSG:TO:${to || ''};SUB:${encodeURIComponent(subj || '')};BODY:${encodeURIComponent(body || '')};;`;

        case 'sms':
          const smsPhone = (document.getElementById('input-sms-phone') as HTMLInputElement)?.value.trim();
          const smsBody = (document.getElementById('input-sms-body') as HTMLTextAreaElement)?.value.trim();
          // Format: smsto:number:message
          return `SMSTO:${smsPhone || ''}:${smsBody || ''}`;

        case 'phone':
          const phoneNum = (document.getElementById('input-phone-num') as HTMLInputElement)?.value.trim();
          return `TEL:${phoneNum || ''}`;

        default:
          return 'https://example.com';
      }
    }

    // --- Custom Canvas Rendering Engine ---
    let renderingTimeout: number;

    function triggerQrUpdate() {
      clearTimeout(renderingTimeout);
      renderingTimeout = setTimeout(() => {
        updateQrCode();
      }, 150) as unknown as number;
    }

    function updateQrCode() {
      const placeholder = document.getElementById('qr-placeholder');
      if (placeholder) placeholder.classList.add('hidden');
      if (qrCanvas) qrCanvas.classList.remove('opacity-20');

      try {
        const content = generateQrContent();
        
        // Grab current style selections
        const dotStyle = (document.getElementById('select-dot-style') as HTMLSelectElement)?.value || 'square';
        const finderStyle = (document.getElementById('select-finder-style') as HTMLSelectElement)?.value || 'square';
        const errorCorrection = (document.getElementById('select-error-level') as HTMLSelectElement)?.value || 'M';
        const fgColorVal = colorFg.value;
        const bgColorVal = colorBg.value;
        const isTransparent = checkTransparent.checked;
        const resolution = parseInt((document.getElementById('select-resolution') as HTMLSelectElement)?.value || '512');
        const logoSize = parseFloat(logoSizeSlider.value) / 100;

        // Generate base QR code modules
        const qr = QRCode.create(content, { errorCorrectionLevel: errorCorrection as QRCode.QRCodeErrorCorrectionLevel });
        const size = qr.modules.size;
        const ctx = qrCanvas.getContext('2d');
        if (!ctx) return;

        // Set canvas resolutions
        qrCanvas.width = resolution;
        qrCanvas.height = resolution;
        ctx.clearRect(0, 0, resolution, resolution);

        // Draw background
        if (!isTransparent) {
          ctx.fillStyle = bgColorVal;
          ctx.fillRect(0, 0, resolution, resolution);
        }

        // Margin in modules
        const margin = 4;
        const totalModules = size + margin * 2;
        const cellSize = resolution / totalModules;
        const offset = margin * cellSize;

        ctx.fillStyle = fgColorVal;
        ctx.strokeStyle = fgColorVal;

        // Boundaries check
        const isFinder = (row: number, col: number) => {
          return (
            (row < 7 && col < 7) || // Top-left
            (row < 7 && col >= size - 7) || // Top-right
            (row >= size - 7 && col < 7) // Bottom-left
          );
        };

        // Draw individual modules
        for (let r = 0; r < size; r++) {
          for (let c = 0; c < size; c++) {
            if (isFinder(r, c)) continue;
            
            const isDark = qr.modules.get(r, c);
            if (!isDark) continue;

            const x = offset + c * cellSize;
            const y = offset + r * cellSize;

            if (dotStyle === 'dots') {
              ctx.beginPath();
              ctx.arc(x + cellSize / 2, y + cellSize / 2, cellSize * 0.4, 0, 2 * Math.PI);
              ctx.fill();
            } else if (dotStyle === 'rounded') {
              ctx.beginPath();
              ctx.roundRect(x + cellSize * 0.05, y + cellSize * 0.05, cellSize * 0.9, cellSize * 0.9, cellSize * 0.25);
              ctx.fill();
            } else {
              // Standard sharp square
              ctx.fillRect(x, y, cellSize, cellSize);
            }
          }
        }

        // Draw Corner Finder Patterns
        const drawFinderPattern = (x: number, y: number) => {
          ctx.lineWidth = cellSize;
          ctx.strokeStyle = fgColorVal;
          ctx.fillStyle = fgColorVal;

          const rOuter = finderStyle === 'rounded' ? cellSize * 1.5 : 0;
          const rInner = finderStyle === 'rounded' ? cellSize * 0.5 : 0;

          // Draw outer stroke square (7 modules wide, but stroke draws from center, so 6-module span)
          ctx.beginPath();
          ctx.roundRect(x + cellSize / 2, y + cellSize / 2, cellSize * 6, cellSize * 6, rOuter);
          ctx.stroke();

          // Draw solid inner square (3x3 modules)
          ctx.beginPath();
          ctx.roundRect(x + cellSize * 2, y + cellSize * 2, cellSize * 3, cellSize * 3, rInner);
          ctx.fill();
        };

        // Draw finder eyes
        drawFinderPattern(offset, offset); // TL
        drawFinderPattern(offset + (size - 7) * cellSize, offset); // TR
        drawFinderPattern(offset, offset + (size - 7) * cellSize); // BL

        // Draw Center Logo overlay if uploaded
        if (uploadedLogoImage) {
          const qrRealSize = size * cellSize;
          const maxLogoSize = qrRealSize * logoSize;
          
          const logoX = offset + (qrRealSize - maxLogoSize) / 2;
          const logoY = offset + (qrRealSize - maxLogoSize) / 2;

          // Background box padding
          const bgPadding = cellSize * 0.5;
          const cardSize = maxLogoSize + bgPadding * 2;
          const cardX = logoX - bgPadding;
          const cardY = logoY - bgPadding;

          // Draw backdrop card
          ctx.fillStyle = isTransparent ? '#ffffff' : bgColorVal;
          ctx.beginPath();
          ctx.roundRect(cardX, cardY, cardSize, cardSize, finderStyle === 'rounded' ? cellSize : 2);
          ctx.fill();

          // Delicate outline around logo card
          ctx.lineWidth = 1;
          ctx.strokeStyle = '#ebebeb';
          ctx.stroke();

          // Render Logo
          ctx.drawImage(uploadedLogoImage, logoX, logoY, maxLogoSize, maxLogoSize);
        }

      } catch (err) {
        console.error('QR Engine Render Error:', err);
      }
    }

    // Attach listeners to all inputs to refresh QR code on type or select
    inputs.forEach((input) => {
      input.addEventListener('input', triggerQrUpdate);
      input.addEventListener('change', triggerQrUpdate);
    });

    // --- PNG/SVG Exporters ---
    if (btnDownloadPng) {
      btnDownloadPng.addEventListener('click', () => {
        if (!qrCanvas) return;

        // Force a brief check that we have content
        const url = qrCanvas.toDataURL('image/png');
        const link = document.createElement('a');
        link.download = `qrcode_${activeTab}_${Date.now()}.png`;
        link.href = url;
        link.click();
        
        saveToHistory();
        showToast('PNG QR code downloaded successfully.');
      });
    }

    if (btnDownloadSvg) {
      btnDownloadSvg.addEventListener('click', () => {
        const svgString = getSvgString();
        const blob = new Blob([svgString], { type: 'image/svg+xml;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.download = `qrcode_${activeTab}_${Date.now()}.svg`;
        link.href = url;
        link.click();
        URL.revokeObjectURL(url);

        saveToHistory();
        showToast('SVG vector QR code downloaded successfully.');
      });
    }

    if (btnCopyImg) {
      btnCopyImg.addEventListener('click', () => {
        if (!qrCanvas) return;

        qrCanvas.toBlob((blob) => {
          if (!blob) return;
          try {
            const item = new ClipboardItem({ 'image/png': blob });
            navigator.clipboard.write([item]).then(() => {
              showToast('QR Image copied to clipboard.');
              saveToHistory();
            });
          } catch (err) {
            console.error('Copy Image Clipboard API failed:', err);
            showToast('Unable to copy image. Try downloading it instead.');
          }
        }, 'image/png');
      });
    }

    if (btnCopySvg) {
      btnCopySvg.addEventListener('click', () => {
        const svgString = getSvgString();
        navigator.clipboard.writeText(svgString).then(() => {
          showToast('SVG markup code copied to clipboard.');
          saveToHistory();
        });
      });
    }

    if (btnPrint) {
      btnPrint.addEventListener('click', () => {
        const contentVal = generateQrContent();
        
        // Open a clean printable print page layout in an iframe or popup
        const printWindow = window.open('', '_blank');
        if (!printWindow) return;

        const dataUrl = qrCanvas.toDataURL('image/png');
        
        printWindow.document.write(`
          <!DOCTYPE html>
