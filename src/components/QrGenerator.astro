<!-- Global Success Toast Notification -->
<div id="toast-success" role="status" aria-live="polite" class="fixed bottom-6 right-6 z-50 bg-primary text-on-primary rounded-md px-4 py-3 shadow-level-5 flex items-center gap-2 transform translate-y-12 opacity-0 pointer-events-none transition-all duration-300">
  <svg class="text-success" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  <span id="toast-message" class="text-xs font-medium font-sans">Copied to clipboard.</span>
</div>

<script>
  // Dynamic client logic for tabs, forms, accordion, history and QR canvas rendering.
  import QRCode from 'qrcode';

  document.addEventListener('DOMContentLoaded', () => {
    // Canvas Fallback for roundRect
    const canvasObj = document.getElementById('qr-canvas') as HTMLCanvasElement;
    if (canvasObj) {
      const ctx = canvasObj.getContext('2d');
      if (ctx && !ctx.roundRect) {
        ctx.roundRect = function (x, y, w, h, r) {
          if (typeof r === 'number') {
            r = [r, r, r, r];
          }
          if (r.length === 1) r = [r[0], r[0], r[0], r[0]];
          if (r.length === 2) r = [r[0], r[1], r[0], r[1]];
          if (r.length === 3) r = [r[0], r[1], r[2], r[1]];
          this.beginPath();
          this.moveTo(x + r[0], y);
          this.lineTo(x + w - r[1], y);
          this.quadraticCurveTo(x + w, y, x + w, y + r[1]);
          this.lineTo(x + w, y + h - r[2]);
          this.quadraticCurveTo(x + w, y + h, x + w - r[2], y + h);
          this.lineTo(x + r[3], y + h);
          this.quadraticCurveTo(x, y + h, x, y + h - r[3]);
          this.lineTo(x, y + r[0]);
          this.quadraticCurveTo(x, y, x + r[0], y);
          this.closePath();
          return this;
        };
      }
    }

    // Logo image tracking
    let uploadedLogoImage: HTMLImageElement | null = null;
    let uploadedLogoFilename = '';
    let uploadedLogoDataUrl = ''; // Base64 data for SVG inclusion

    // --- State variables ---
    let activeTab = 'url';
    const historyKey = 'universal_qr_history_v1';

    // --- DOM Elements ---
    const tabsContainer = document.getElementById('content-tabs');
    const tabPanes = document.querySelectorAll('.tab-pane');
    const tabBtns = document.querySelectorAll('.tab-btn');
    const inputs = document.querySelectorAll('.form-input-box, .opt-control');
    const qrCanvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
    
    // Logo Upload controls
    const logoUpload = document.getElementById('logo-upload') as HTMLInputElement;
    const logoFilename = document.getElementById('logo-filename');
    const btnClearLogo = document.getElementById('btn-clear-logo');
    const logoSettingsPanel = document.getElementById('logo-settings-panel');
    const logoSizeSlider = document.getElementById('logo-size-slider') as HTMLInputElement;
    const logoSizeValue = document.getElementById('logo-size-value');
    
    // Custom Color Input Bindings
    const colorFg = document.getElementById('color-fg') as HTMLInputElement;
    const colorFgText = document.getElementById('color-fg-text') as HTMLInputElement;
    const colorBg = document.getElementById('color-bg') as HTMLInputElement;
    const colorBgText = document.getElementById('color-bg-text') as HTMLInputElement;
    const checkTransparent = document.getElementById('check-transparent') as HTMLInputElement;
    
    // Action Buttons
    const btnDownloadPng = document.getElementById('btn-download-png');
    const btnDownloadSvg = document.getElementById('btn-download-svg');
    const btnCopyImg = document.getElementById('btn-copy-img');
    const btnCopySvg = document.getElementById('btn-copy-svg');
    const btnPrint = document.getElementById('btn-print');
    
    // History DOM elements
    const historyEmpty = document.getElementById('history-empty');
    const historyGrid = document.getElementById('history-grid');
    const btnClearHistory = document.getElementById('btn-clear-history');
    
    // Toast elements
    const toast = document.getElementById('toast-success');
    const toastMsg = document.getElementById('toast-message');

    // --- Tabs Logic ---
    if (tabsContainer) {
      tabsContainer.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const button = target.closest('.tab-btn');
        if (!button) return;

        const tab = button.getAttribute('data-tab');
        if (!tab) return;

        activeTab = tab;

        // Update button states
        tabBtns.forEach((btn) => {
          btn.classList.remove('active', 'bg-primary', 'text-on-primary');
          btn.classList.add('text-body', 'hover:text-ink', 'hover:bg-canvas-soft-2');
          btn.setAttribute('aria-selected', 'false');
        });
        button.classList.add('active', 'bg-primary', 'text-on-primary');
        button.classList.remove('text-body', 'hover:text-ink', 'hover:bg-canvas-soft-2');
        button.setAttribute('aria-selected', 'true');

        // Toggle visibility of panels
        tabPanes.forEach((pane) => pane.classList.add('hidden'));
        const targetPanel = document.getElementById(`tab-content-${tab}`);
        if (targetPanel) targetPanel.classList.remove('hidden');

        triggerQrUpdate();
      });
    }

    // --- Accordion Toggle Logic ---
    const accordionTriggers = document.querySelectorAll('[data-accordion-trigger]');
    accordionTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.accordion-item');
        if (!item) return;

        const chevron = trigger.querySelector('.chevron');
        const content = item.querySelector('.accordion-content');

        if (content) {
          content.classList.toggle('hidden');
          chevron?.classList.toggle('rotate-180');
        }
      });
    });

    // Collapse all accordions except the first on load
    const accordionItems = document.querySelectorAll('.accordion-item');
    accordionItems.forEach((item, index) => {
      if (index > 0) {
        const trigger = item.querySelector('[data-accordion-trigger]');
        const content = item.querySelector('.accordion-content');
        const chevron = trigger?.querySelector('.chevron');
        
        content?.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      }
    });

    // --- Color Picker Dual Inputs Sync ---
    if (colorFg && colorFgText) {
      colorFg.addEventListener('input', () => {
        colorFgText.value = colorFg.value.toUpperCase();
        triggerQrUpdate();
      });
      colorFgText.addEventListener('input', () => {
        if (/^#[0-9A-F]{6}$/i.test(colorFgText.value)) {
          colorFg.value = colorFgText.value;
          triggerQrUpdate();
        }
      });
    }

    if (colorBg && colorBgText) {
      colorBg.addEventListener('input', () => {
        colorBgText.value = colorBg.value.toUpperCase();
        triggerQrUpdate();
      });
      colorBgText.addEventListener('input', () => {
        if (/^#[0-9A-F]{6}$/i.test(colorBgText.value)) {
          colorBg.value = colorBgText.value;
          triggerQrUpdate();
        }
      });
    }

    // Transparent bg sync
    if (checkTransparent && colorBg && colorBgText) {
      checkTransparent.addEventListener('change', () => {
        const isTransparent = checkTransparent.checked;
        colorBg.disabled = isTransparent;
        colorBgText.disabled = isTransparent;
        if (isTransparent) {
          colorBgText.classList.add('opacity-50');
        } else {
          colorBgText.classList.remove('opacity-50');
        }
        triggerQrUpdate();
      });
    }

    // Color Presets Handlers
    const presetButtons = document.querySelectorAll('.preset-theme-btn');
    presetButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const fg = btn.getAttribute('data-fg');
        const bg = btn.getAttribute('data-bg');
        
        presetButtons.forEach(b => {
          const tick = b.querySelector('.active-check');
          tick?.classList.remove('scale-100');
          tick?.classList.add('scale-0');
        });

        const activeTick = btn.querySelector('.active-check');
        activeTick?.classList.remove('scale-0');
        activeTick?.classList.add('scale-100');

        if (fg && bg) {
          colorFg.value = fg;
          colorFgText.value = fg.toUpperCase();
          colorBg.value = bg;
          colorBgText.value = bg.toUpperCase();
          checkTransparent.checked = false;
          colorBg.disabled = false;
          colorBgText.disabled = false;
          colorBgText.classList.remove('opacity-50');
          triggerQrUpdate();
        }
      });
    });

    // Make the first theme check active on start
    const firstPreset = presetButtons[0];
    if (firstPreset) {
      const tick = firstPreset.querySelector('.active-check');
      tick?.classList.remove('scale-0');
      tick?.classList.add('scale-100');
    }

    // --- Logo Upload Logic ---
    if (logoUpload) {
      logoUpload.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        const files = target.files;
        if (!files || files.length === 0) return;

        const file = files[0];
        uploadedLogoFilename = file.name;
        
        if (logoFilename) logoFilename.textContent = file.name;
        btnClearLogo?.classList.remove('hidden');
        logoSettingsPanel?.classList.remove('hidden');

        // Automatically boost error correction level to HIGH (H) to compensate for embedded logo obstruction
        const selectErrorLevel = document.getElementById('select-error-level') as HTMLInputElement;
        if (selectErrorLevel) {
          selectErrorLevel.value = 'H';
        }

        const reader = new FileReader();
        reader.onload = (event) => {
          const img = new Image();
          img.onload = () => {
            uploadedLogoImage = img;
            uploadedLogoDataUrl = event.target?.result as string;
            triggerQrUpdate();
          };
          img.src = event.target?.result as string;
        };
        reader.readAsDataURL(file);
      });
    }

    if (btnClearLogo) {
      btnClearLogo.addEventListener('click', () => {
        uploadedLogoImage = null;
        uploadedLogoFilename = '';
        uploadedLogoDataUrl = '';
        if (logoUpload) logoUpload.value = '';
        if (logoFilename) logoFilename.textContent = 'No file uploaded';
        btnClearLogo.classList.add('hidden');
        logoSettingsPanel?.classList.add('hidden');

        // Reset error correction back to Medium (M) if not custom overridden
        const selectErrorLevel = document.getElementById('select-error-level') as HTMLInputElement;
        if (selectErrorLevel) {
          selectErrorLevel.value = 'M';
        }

        triggerQrUpdate();
      });
    }

    if (logoSizeSlider && logoSizeValue) {
      logoSizeSlider.addEventListener('input', () => {
        logoSizeValue.textContent = `${logoSizeSlider.value}%`;
