---
import Layout from '../layouts/Layout.astro';

const title = 'Terms & Conditions | Universal QR Code Tools';
const description = 'Review the terms and conditions for using Universal QR Code Tools, a free online QR code generator.';
const canonical = new URL('/terms-and-conditions/', Astro.site ?? Astro.url.origin).toString();
const updated = 'July 13, 2026';
---

<Layout title={title} description={description} canonical={canonical}>
  <main class="flex-grow bg-canvas-soft">
    <section class="w-full border-b border-hairline bg-canvas py-16 md:py-20">
      <div class="w-full max-w-7xl mx-auto px-4 md:px-6">
        <div class="max-w-3xl space-y-5">
          <p class="text-xs font-mono uppercase text-body">Terms & Conditions</p>
          <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-ink leading-tight text-pretty">
            Terms for using Universal QR Code Tools.
          </h1>
          <p class="text-sm text-body font-mono">Last updated: {updated}</p>
        </div>
      </div>
    </section>

    <section class="w-full py-16">
      <div class="w-full max-w-3xl mx-auto px-4 md:px-6 space-y-8 text-sm md:text-base leading-relaxed text-body">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold tracking-tight text-ink">Use of the Tool</h2>
          <p>
            Universal QR Code Tools provides a free online QR code generator for creating and downloading QR codes. You are responsible for the content you enter, the destinations you encode, and how you distribute the generated QR codes.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-2xl font-semibold tracking-tight text-ink">Acceptable Use</h2>
          <p>
            Do not use the tool to create QR codes that lead to phishing pages, malware, deceptive content, unlawful material, or content that infringes the rights of others. You should test every QR code before publishing or printing it.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-2xl font-semibold tracking-tight text-ink">Static QR Codes</h2>
          <p>
            QR codes created by this generator are static. Once printed or shared, the encoded content cannot be changed unless you create and distribute a new QR code.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-2xl font-semibold tracking-tight text-ink">No Warranty</h2>
          <p>
            The tool is provided as is. We aim to keep the generator useful and reliable, but we do not guarantee uninterrupted availability, scan performance in every environment, or suitability for every project.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-2xl font-semibold tracking-tight text-ink">Changes</h2>
          <p>
            We may update these terms as the product changes. Continued use of the site after updates means you accept the revised terms.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
