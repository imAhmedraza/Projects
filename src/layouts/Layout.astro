---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Universal QR Code Generator | Premium Designer Utilities",
	description = "Generate customized, print-ready, high-fidelity QR codes with custom styling, dot shape adjustments, and logo overlays."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts for Inter (Sans) and JetBrains Mono (Monospace) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="bg-canvas-soft text-ink font-sans selection:bg-primary selection:text-on-primary">
		<div class="relative isolation-isolate">
			<slot />
		</div>
	</body>

</html>
